{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":disableDependencyDashboard"
  ],
  "prHourlyLimit": 0,
  "automerge": true,
  "autoApprove": true,
  
  "packageRules": [
    {
      "schedule": [
        "at any time"
      ],
      "description": "Automerge non-major updates",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "baseBranchPatterns": ["main","master"],
      "automergeType": "branch",
      "automerge": true
    }
  ],
  "automergeType": "branch",
  "ignoreTests": true,
  "platformAutomerge": true
}